# Generated by tools/split_config.py from tracker.config
# Review, then restart the tracker. Keys equal to application
# defaults may be deleted freely — unset keys fall back.

[app]
title = SYC buoy tracker

[webapp]
default_center = N37° 33.16', W122° 11.70'
default_zoom = 13
status_blue_threshold = 3
status_orange_threshold = 12

[battery]
low_battery_threshold = 25

[app_features]
show_all_nodes = false
show_gateways = false
show_position_trails = true
show_nautical_markers = true
trail_history_hours = 80

[special_nodes_settings]
stale_after_hours = 12
special_symbol = ⭐
data_limit_time = 0.25
lpu_blue_threshold_hours = 3
lpu_orange_threshold_hours = 8
sol_blue_threshold_hours = 2
sol_orange_threshold_hours = 6

[special_nodes]
movement_threshold = 150
3681533965 = SYCS, N37° 33.81', W122° 13.13', true
492590216 = SYCE, N37° 34.81', W122° 13.07', true
2512106321 = SYCA, N37° 31.94', W122° 10.31', true
2009991947 = SYCX, N37° 34.23', W122° 12.13', true
3280278694 = SYCO, N37° 33.61', W122° 11.16', true
800188038 = SYCP, N37° 33.51', W122° 11.27', true

[alerts]
enabled = true
alert_cooldown = 1

