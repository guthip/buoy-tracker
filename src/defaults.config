# ============================================================================
# Buoy Tracker — APPLICATION DEFAULTS (shipped inside the image)
# ============================================================================
# Do not edit in a deployment. Override values in:
#   config/site.config         — what the fleet is (buoys, homes, alert policy)
#   config/environment.config  — where it runs (broker, ports, smtp, logging)
#   config/secret.config       — credentials (api_key, smtp password)
# Later files win; secrets win over all files; UI/database overrides win last.
# ============================================================================

[app]
title = Buoy Tracker

[mqtt]
broker = mqtt.bayme.sh
port = 1883
root_topic = msh/US/bayarea/2/e/
channel_name = MediumFast
username = meshdev
password = large4cats
encryption_key = AQ==

[webapp]
host = 0.0.0.0
port = 5103
default_center = 37.7749,-122.4194
default_zoom = 13
status_blue_threshold = 3
status_orange_threshold = 12
api_polling_interval = 10

[debug]
log_level = ERROR
enable_simulation = false
send_real_emails = false
alert_window_s = 0
alert_cooldown_s = 0

[database]
retention_days = 90

[battery]
low_battery_threshold = 25

[app_features]
show_all_nodes = false
show_gateways = false
show_position_trails = true
show_nautical_markers = true
trail_history_hours = 168

[special_nodes_settings]
stale_after_hours = 12
special_symbol = ⭐
data_limit_time = 1.0
lpu_blue_threshold_hours = 3
lpu_orange_threshold_hours = 8
sol_blue_threshold_hours = 2
sol_orange_threshold_hours = 6

[special_nodes]
movement_threshold = 50

[alerts]
enabled = false
alert_cooldown = 1
email_from = noreply@example.com
smtp_host = localhost
smtp_port = 25
smtp_ssl = false

[security]
environment = development
trusted_proxies =
allowed_origins = *
