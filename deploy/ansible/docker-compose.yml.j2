#----------------------------------------------------------------------------
# Buoy Tracker service — generated by ansible ({{ role_title | default('buoy role') }})
#----------------------------------------------------------------------------
services:
  buoy-tracker:
    container_name: {{ buoy_role_project | default('buoy-tracker') }}
    image: dokwerker8891/buoy-tracker:{{ buoy_role_image_tag | default('2.2') }}
    restart: unless-stopped
{% if buoy_role_map_ports | default(true) %}
    ports:
      - "{{ buoy_role_ui_port }}:5103"
{% endif %}
    volumes:
      - ./config:/app/config
      - ./data:/app/data
      - ./logs:/app/logs
    environment:
      PUID: "{{ buoy_role_puid | default(1000) }}"
      PGID: "{{ buoy_role_pgid | default(1000) }}"
      TZ: "{{ buoy_role_tz | default('UTC') }}"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:5103/health"]
      interval: 30s
      timeout: 5s
      retries: 3
{% if buoy_role_traefik | default(false) %}
    labels:
      - "traefik.enable=true"
{% if buoy_role_traefik_pathprefix | default('') %}
      # Subpath style: www.example.com/{{ buoy_role_traefik_pathprefix }}
      # stripprefix sends X-Forwarded-Prefix automatically — the app adapts,
      # no app config needed (v2.1)
      - "traefik.http.routers.{{ buoy_role_project }}.rule=Host(`{{ buoy_role_app_fqdn }}`) && PathPrefix(`/{{ buoy_role_traefik_pathprefix }}`)"
      - "traefik.http.routers.{{ buoy_role_project }}.middlewares={{ buoy_role_project }}-stripprefix"
      - "traefik.http.middlewares.{{ buoy_role_project }}-stripprefix.stripprefix.prefixes=/{{ buoy_role_traefik_pathprefix }}"
{% else %}
      # Subdomain style: {{ buoy_role_app_fqdn }}
      - "traefik.http.routers.{{ buoy_role_project }}.rule=Host(`{{ buoy_role_app_fqdn }}`)"
{% endif %}
      - "traefik.http.routers.{{ buoy_role_project }}.entrypoints=https"
      - "traefik.http.routers.{{ buoy_role_project }}.tls.certresolver={{ buoy_role_certresolver | default('cloudflare') }}"
      - "traefik.http.services.{{ buoy_role_project }}.loadbalancer.server.port=5103"
{% endif %}
{% if buoy_role_network | default('') %}

networks:
  default:
    name: {{ buoy_role_network }}
    external: true
{% endif %}
