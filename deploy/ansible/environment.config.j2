#----------------------------------------------------------------------------
# environment.config — generated by ansible. WHERE the tracker runs.
# Fleet identity lives in site.config (club-owned, copied verbatim).
# Unset keys fall back to application defaults shipped in the image.
#----------------------------------------------------------------------------
[webapp]
host = 0.0.0.0
port = 5103

[alerts]
email_from = {{ buoy_role_project | default('buoy-tracker') }}@{{ host_domain }}
smtp_host = {{ buoy_smtp_host }}
smtp_port = {{ buoy_smtp_port }}
smtp_ssl = false
tracker_url = https://{{ buoy_role_app_fqdn }}

[debug]
log_level = ERROR

[security]
environment = production
